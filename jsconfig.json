{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "checkJs": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noUnusedLocals": false,
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "preserve",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ]
    },
    "include": [
        "src/app/**/*.js",
        "src/app/**/*.jsx",
        "src/features/**/*.js",
        "src/features/**/*.jsx",
        "src/components/**/*.js",
        "src/components/**/*.jsx",
        "src/lib/**/*.js",
        "src/lib/**/*.jsx",
        "src/store/**/*.js",
        "src/hooks/**/*.js",
        "src/middleware.js"
    ],
    "exclude": [
        "node_modules",
        ".next",
        "src/__tests__",
        "src/scripts",
        "src/ai"
    ]
}