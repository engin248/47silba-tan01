# ═══════════════════════════════════════════════════
# THE ORDER / NİZAM — ÇEVRE DEĞİŞKENLERİ ŞABLONU
# Bu dosyayı .env.local olarak kopyalayın
# ASLA git'e commit etmeyin — .gitignore'da
# Güncel: 23 Mart 2026
# ═══════════════════════════════════════════════════

# ─── SUPABASE (Zorunlu) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://cauptlsnqieegdrgotob.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=BURAYA_SUPABASE_ANON_KEY_YAZIN
SUPABASE_SERVICE_ROLE_KEY=BURAYA_SERVICE_ROLE_KEY_YAZIN

# ─── GÜVENLİK (Zorunlu) ───────────────────────────
# JWT imza anahtarı — min 32 karakter, crypto-random
# Üretmek: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SIRRI=BURAYA_64_HEX_RANDOM_YAZIN

# Sunucu-sunucu cron/ajan çağrıları için iç API anahtarı
INTERNAL_API_KEY=BURAYA_64_HEX_RANDOM_YAZIN

# Koordinatör girişi PIN
COORDINATOR_PIN=BURAYA_PIN_YAZIN

# Üretim hattı PIN
URETIM_PIN=BURAYA_URETIM_PIN_YAZIN

# Genel PIN
GENEL_PIN=BURAYA_GENEL_PIN_YAZIN

# ─── TELEGRAM BOT (Zorunlu) ───────────────────────
TELEGRAM_BOT_TOKEN=BURAYA_BOT_TOKEN_YAZIN
TELEGRAM_CHAT_ID=BURAYA_CHAT_ID_YAZIN
TELEGRAM_ADMIN_CHAT_ID=BURAYA_ADMIN_CHAT_ID_YAZIN
TELEGRAM_WEBHOOK_SECRET=BURAYA_48_HEX_RANDOM_YAZIN

# ─── UPSTASH REDIS (Zorunlu — Rate Limiting) ──────
# upstash.com → Redis DB → REST API sekmesi
UPSTASH_REDIS_REST_URL=BURAYA_UPSTASH_URL_YAZIN
UPSTASH_REDIS_REST_TOKEN=BURAYA_UPSTASH_TOKEN_YAZIN

# ─── MESAJ ŞİFRELEME (Zorunlu) ────────────────────
# 64 hex char — crypto-random
NEXT_PUBLIC_HABERLESME_MASTER_KEY=BURAYA_64_HEX_RANDOM_YAZIN

# ─── YAPAY ZEKA APILERİ (Opsiyonel) ───────────────
GEMINI_API_KEY=BURAYA_GEMINI_KEY_YAZIN
OPENAI_API_KEY=BURAYA_OPENAI_KEY_YAZIN
PERPLEXITY_API_KEY=BURAYA_PERPLEXITY_KEY_YAZIN
DEEPSEEK_API_KEY=BURAYA_DEEPSEEK_KEY_YAZIN
SERPAPI_API_KEY=BURAYA_SERPAPI_KEY_YAZIN

# ─── SENTRY (Opsiyonel — Hata İzleme) ─────────────
NEXT_PUBLIC_SENTRY_DSN=BURAYA_SENTRY_DSN_YAZIN

# ─── KAMERA / STREAM (Opsiyonel) ──────────────────
# go2rtc kurulduktan sonra cloudflare tüneli URL
NEXT_PUBLIC_GO2RTC_URL=BURAYA_GO2RTC_URL_YAZIN

# ─── ÜRETİM PARAMETRELERİ ─────────────────────────
NEXT_PUBLIC_DAKIKA_UCRETI=2.50
